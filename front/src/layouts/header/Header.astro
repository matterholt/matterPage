---
import NavBar from "@components/custom/Navbar.astro";
import Text from "@components/base/text/Text.astro";
import Logo from "@components/custom/Logo.astro";

interface Props {
  title: string;
}

const { title } = Astro.props;
---

<header class="main_headerLayout">
  <div class="header_logo">
    <Logo size={80} />
  </div>
  <div class="header_navBar">
    <NavBar />
  </div>
  <div class="header_titleLayout">
    {title ? <Text tag="h1">{title}</Text> : <Text tag="h1">Matterholt</Text>}
  </div>
</header>
<style>
  .main_headerLayout {
    display: grid;
    grid-template-columns: 125px 1fr;
    grid-template-rows: 100px 1fr;
  }
  .header_logo {
    padding: 20px;
    display: grid;
    grid-row: 1;
    grid-column: 1;
    place-items: center;
  }
  .header_navBar {
  }
  .header_titleLayout {
    grid-column: 1/3;
    grid-row: 2;
    place-self: center;
  }
  @media screen and (max-width: 790px) {
    .main_headerLayout {
      grid-template-columns: 1fr;
      grid-template-rows: 100px 80px 1fr;
    }
    .header_titleLayout {
      grid-column: 1;
      grid-row: 3;
    }
    .header_navBar {
      grid-column: 1;
      grid-row: 2;
    }
  }
</style>
