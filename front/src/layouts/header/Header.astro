---
import Navigation from "@layouts/navigation/Navigation.astro";
import Text from "@components/base/text/Text.astro";
import Logo from "@components/custom/Logo.astro";

interface Props {
  title: string;
}

const { title } = Astro.props;
---

<header class="main_headerLayout">
  <div class="header_logo">
    <Logo size={80} />
  </div>
  <div class="header_navigation">
    <Navigation />
  </div>
  <div class="header_titleLayout">
    {title ? <Text tag="h1">{title}</Text> : <Text tag="h1">Matterholt</Text>}
  </div>
</header>
<style>
  .main_headerLayout {
    width: 100%;
    display: grid;
    grid-template-columns: 25% 1fr;
    grid-template-rows: 50px 100px 1fr;
  }

  .header_logo {
    padding: 20px;
    display: grid;
    grid-row: 1 / 2;
    grid-column: 1;
    place-items: center;
  }
  .header_navigation {
    grid-column: 1 / span 2;
    grid-row: 1;
  }
  .header_titleLayout {
    align-self: center;
    grid-column: 2;
    grid-row: 2;
  }
  @media screen and (max-width: 790px) {
    .main_headerLayout {
      width: 100%;
      grid-template-columns: 1fr 50px;
      grid-template-rows: 100px 1fr;
    }
    .header_logo {
      place-items: flex-start;
    }
    .header_titleLayout {
      grid-column: 1 / span 2;
      grid-row: 3;
    }
    .header_navigation {
      grid-column: 2;
      grid-row: 1;
    }
  }
</style>
