---
interface Props {
  tags?: string[];
}

const { tags = [] } = Astro.props;

const allPosts = Object.values(
  import.meta.glob("@content/articles/*.md", { eager: true }),
);
const uniqueTags = [
  ...new Set(allPosts.map((post: any) => post.frontmatter.tags).flat()),
];

const displayedTags = tags.length === 0 ? uniqueTags : tags;
---

<ul class="taglist tagCollection_list">
  {
    displayedTags.map((tag) => (
      <li class={tag.toLocaleLowerCase()}>
        <a href={`articles/tag/${tag}`}>{tag}</a>
      </li>
    ))
  }
</ul>

<style>
  .selected_tag {
    background-color: #ffffff52;
  }
  .taglist {
    font-size: 10px;
    display: flex;
    list-style: none;
    gap: 10px;
    margin: 0px;
    padding: 10px;
    text-transform: uppercase;
    li {
      padding: 6px;
      border-radius: 5px;
    }
    li:hover {
      margin: 0;
      padding: 5px;
      border: solid 1px #ffffff52;
      cursor: pointer;
    }
  }
</style>
