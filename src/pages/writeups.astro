---
import { PageLayout } from "@layouts/index";
import { PostIntro, Text} from "@components/lib_comps/";
import { filterCollectionsBy } from "@utils/helpers/post_collections/";
import { PageTitleBlock } from "@components/blocks";


const [currentYear, OtherYears] = await filterCollectionsBy("current_year");
---
<PageLayout pageId="write ups">
  <PageTitleBlock>latest Posts</PageTitleBlock>
  {currentYear.map((x) => <PostIntro postFrontMatter={x} />)}
  <Text tag="h2">Previous Years</Text>
  {OtherYears.map((x) => <PostIntro varient="post_intro-simple" postFrontMatter={x} />)}
</PageLayout>
