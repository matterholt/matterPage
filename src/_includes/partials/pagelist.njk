
{% if pagelist %}

<aside class="pageList page__content">
    <article>

        {%- for post in pagelist -%}
        <h2><a href="{{ post.url }}">{{ post.data.title }}</a></h2>
        
        {% if post.data.date %}<p class="time"><time datetime="{{ post.data.date }}">{{ post.data.date }}</time></p>{% endif %}
        
        <p>{{ post.data.slug }}</p>
        
    </article>
    {%- endfor -%}
</aside>


{% endif %}
